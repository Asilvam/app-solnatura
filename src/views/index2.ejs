<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Productos — Solnatura</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigation") %>
        <% const activeCategory = categorias.find((categoria) => categoria.codigo === filters.categoria); %>
        <% const hasActiveFilters = Boolean(filters.q || filters.categoria || filters.oferta || filters.precioMin !== "" || filters.precioMax !== "" || filters.orden !== "recientes"); %>
        <% const orderLabels = { nombre_asc: "Nombre A–Z", nombre_desc: "Nombre Z–A", precio_asc: "Precio menor", precio_desc: "Precio mayor" }; %>
        <% const pageWindowSize = 5; %>
        <% const pageStart = Math.max(1, Math.min(pagination.page - 2, pagination.totalPages - pageWindowSize + 1)); %>
        <% const pageEnd = Math.min(pagination.totalPages, pageStart + pageWindowSize - 1); %>

        <!-- Hero Banner -->
        <section class="hero-section <%= hasActiveFilters ? 'hero-section--compact' : '' %>">
            <div class="hero-overlay"></div>
            <div class="hero-content animate__animated animate__fadeIn">
                <span class="hero-tagline">
                    <i class="fa-solid fa-leaf"></i> Belleza · Cuidado · Bienestar
                </span>
                <h1 class="hero-title">
                    <span class="hero-title-desktop">Belleza y bienestar,<br><strong>elegidos para ti</strong></span>
                    <span class="hero-title-mobile">Encuentra tu favorito</span>
                </h1>
                <p class="hero-subtitle">Explora una selección cuidada de productos para tu rutina, tu hogar y tus regalos.</p>
                <form class="hero-search-form" action="/" method="get">
                    <div class="hero-search-group">
                        <i class="fa-solid fa-magnifying-glass hero-search-icon"></i>
                        <input type="search" name="q" class="hero-search-input" placeholder="¿Qué producto buscas?"
                            value="<%= filters.q %>" aria-label="Buscar" />
                        <button type="submit" class="hero-search-btn">Buscar</button>
                    </div>
                </form>
            </div>
        </section>

        <main id="catalogo" class="container public-catalog-page px-3 px-md-4 py-4">
            <section class="public-catalog-header" aria-labelledby="catalog-title">
                <div>
                    <span class="public-catalog-eyebrow">Catálogo</span>
                    <h2 id="catalog-title">Nuestros productos</h2>
                    <p class="public-results-count mb-0">
                        <strong><%= pagination.total %></strong>
                        <%= pagination.total === 1 ? "producto encontrado" : "productos encontrados" %>
                        <span class="public-results-page">· Página <%= pagination.page %> de <%= pagination.totalPages %></span>
                    </p>
                </div>
                <button class="btn public-filter-toggle" type="button" data-toggle="collapse"
                    data-target="#publicFilters" aria-expanded="false" aria-controls="publicFilters">
                    <i class="fa-solid fa-sliders mr-1"></i> Filtros
                    <% if (hasActiveFilters) { %>
                        <span class="public-filter-dot" aria-label="Hay filtros activos"></span>
                    <% } %>
                </button>
            </section>

            <div class="collapse public-filter-collapse" id="publicFilters">
                <form class="public-filter-card" action="/" method="get">
                    <div class="public-filter-grid">
                        <div class="public-filter-field public-filter-field--search">
                            <label for="public-filter-q">Buscar</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                                </div>
                                <input id="public-filter-q" name="q" type="search" class="form-control"
                                    value="<%= filters.q %>" placeholder="Nombre, código o descripción" />
                            </div>
                        </div>

                        <div class="public-filter-field">
                            <label for="public-filter-category">Categoría</label>
                            <select id="public-filter-category" name="categoria" class="form-control">
                                <option value="">Todas</option>
                                <% categorias.forEach(function (categoria) { %>
                                    <option value="<%= categoria.codigo %>" <%= filters.categoria === categoria.codigo ? "selected" : "" %>>
                                        <%= categoria.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="public-filter-field">
                            <label for="public-filter-min">Precio mínimo</label>
                            <div class="input-group">
                                <div class="input-group-prepend"><span class="input-group-text">$</span></div>
                                <input id="public-filter-min" name="precioMin" type="number" min="0" step="1"
                                    class="form-control" value="<%= filters.precioMin %>" placeholder="0" />
                            </div>
                        </div>

                        <div class="public-filter-field">
                            <label for="public-filter-max">Precio máximo</label>
                            <div class="input-group">
                                <div class="input-group-prepend"><span class="input-group-text">$</span></div>
                                <input id="public-filter-max" name="precioMax" type="number" min="0" step="1"
                                    class="form-control" value="<%= filters.precioMax %>" placeholder="Sin límite" />
                            </div>
                        </div>

                        <div class="public-filter-field">
                            <label for="public-filter-order">Ordenar por</label>
                            <select id="public-filter-order" name="orden" class="form-control">
                                <option value="recientes" <%= filters.orden === "recientes" ? "selected" : "" %>>Más recientes</option>
                                <option value="nombre_asc" <%= filters.orden === "nombre_asc" ? "selected" : "" %>>Nombre A–Z</option>
                                <option value="nombre_desc" <%= filters.orden === "nombre_desc" ? "selected" : "" %>>Nombre Z–A</option>
                                <option value="precio_asc" <%= filters.orden === "precio_asc" ? "selected" : "" %>>Precio menor</option>
                                <option value="precio_desc" <%= filters.orden === "precio_desc" ? "selected" : "" %>>Precio mayor</option>
                            </select>
                        </div>

                        <div class="public-filter-field public-filter-field--offer">
                            <label class="public-offer-check" for="public-filter-offer">
                                <input id="public-filter-offer" name="oferta" type="checkbox" value="si"
                                    <%= filters.oferta === "si" ? "checked" : "" %> />
                                <span class="public-offer-check-box"><i class="fa-solid fa-tag"></i></span>
                                <span>Solo ofertas</span>
                            </label>
                        </div>
                    </div>

                    <div class="public-filter-actions">
                        <a href="/" class="btn btn-light">Limpiar</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-filter mr-1"></i> Aplicar filtros
                        </button>
                    </div>
                </form>
            </div>

            <% if (hasActiveFilters) { %>
                <div class="public-active-filters" aria-label="Filtros activos">
                    <span class="public-active-label">Filtros activos:</span>
                    <% if (filters.q) { %>
                        <a class="public-filter-chip" href="<%= publicUrl({ q: '', page: 1 }) %>"
                            aria-label="Quitar búsqueda <%= filters.q %>">
                            “<%= filters.q %>” <i class="fa-solid fa-xmark"></i>
                        </a>
                    <% } %>
                    <% if (filters.categoria) { %>
                        <a class="public-filter-chip" href="<%= publicUrl({ categoria: '', page: 1 }) %>"
                            aria-label="Quitar categoría">
                            <%= activeCategory ? activeCategory.nombre : filters.categoria %>
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    <% } %>
                    <% if (filters.oferta) { %>
                        <a class="public-filter-chip" href="<%= publicUrl({ oferta: '', page: 1 }) %>"
                            aria-label="Quitar filtro de ofertas">
                            Solo ofertas <i class="fa-solid fa-xmark"></i>
                        </a>
                    <% } %>
                    <% if (filters.precioMin !== '' || filters.precioMax !== '') { %>
                        <a class="public-filter-chip" href="<%= publicUrl({ precioMin: '', precioMax: '', page: 1 }) %>"
                            aria-label="Quitar rango de precio">
                            <% if (filters.precioMin !== '' && filters.precioMax !== '') { %>
                                $<%= Number(filters.precioMin).toLocaleString('es-CL') %>–$<%= Number(filters.precioMax).toLocaleString('es-CL') %>
                            <% } else if (filters.precioMin !== '') { %>
                                Desde $<%= Number(filters.precioMin).toLocaleString('es-CL') %>
                            <% } else { %>
                                Hasta $<%= Number(filters.precioMax).toLocaleString('es-CL') %>
                            <% } %>
                            <i class="fa-solid fa-xmark"></i>
                        </a>
                    <% } %>
                    <% if (filters.orden !== 'recientes') { %>
                        <a class="public-filter-chip" href="<%= publicUrl({ orden: 'recientes', page: 1 }) %>"
                            aria-label="Restablecer orden">
                            <%= orderLabels[filters.orden] %> <i class="fa-solid fa-xmark"></i>
                        </a>
                    <% } %>
                    <a class="public-clear-filters" href="/">Limpiar todo</a>
                </div>
            <% } %>

            <% if (images.length === 0) { %>
                <div class="public-empty-state">
                    <span class="public-empty-icon"><i class="fa-solid fa-seedling"></i></span>
                    <h3>No encontramos productos</h3>
                    <p>Prueba con otra búsqueda o elimina algunos filtros para ampliar los resultados.</p>
                    <a href="/" class="btn btn-primary rounded-pill px-4">Ver todos los productos</a>
                </div>
            <% } else { %>
                <div class="catalogo-grid">
                <% images.forEach(function (image) { %>
                    <% const hasOffer = Number(image.precioAnterior) > Number(image.precio) && Number(image.precio) > 0; %>
                    <% const discountPercentage = hasOffer ? Math.round((1 - Number(image.precio) / Number(image.precioAnterior)) * 100) : 0; %>
                    <% const productCategory = categorias.find((categoria) => categoria.codigo === image.categoria); %>
                    <div class="card product-card animate__animated animate__fadeInUp" data-toggle="modal"
                        data-target="#productModal" data-title="<%= image.title %>"
                        data-description="<%= image.description %>" data-precio="<%= image.precio %>"
                        data-precio-anterior="<%= image.precioAnterior || 0 %>" data-stock="<%= image.cantidad %>"
                        data-codigo="<%= image.codigo %>" data-ciclo="<%= image.ciclo %>" data-path="<%= image.path %>">
                        <div class="card-img-wrapper skeleton-loading">
                            <% if (hasOffer) { %>
                                <span class="product-image-badge product-offer-badge">
                                    <i class="fa-solid fa-tag"></i>
                                    <strong>-<%= discountPercentage %>%</strong>
                                    <span>Oferta</span>
                                </span>
                            <% } %>
                            <img src="<%= image.path %>" class="card-img-top" alt="<%= image.title %>"
                                onload="this.parentElement.classList.remove('skeleton-loading');" loading="lazy" />
                        </div>

                        <div class="public-product-category"
                            title="<%= productCategory ? productCategory.nombre : image.categoria %>">
                            <%= productCategory ? productCategory.nombre : image.categoria %>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <%= image.title %>
                            </h5>

                            <div class="product-price-row mb-2">
                                <div class="product-price-block">
                                    <% if (hasOffer) { %>
                                        <span class="product-old-price">$ <%= Number(image.precioAnterior || 0).toLocaleString('es-CL') %></span>
                                    <% } %>
                                    <span class="badge-precio">$ <%= Number(image.precio || 0).toLocaleString('es-CL') %></span>
                                </div>
                            </div>

                            <p class="text-muted small mb-1">
                                <i class="fa-solid fa-barcode"></i>
                                <%= image.codigo %>
                            </p>

                            <p class="text-muted small mb-3 public-product-description">
                                <%= image.description %>
                            </p>

                            <button type="button" data-cart-add class="btn btn-add-cart btn-block mt-auto">
                                <i class="fa-solid fa-cart-plus"></i>
                                Añadir al carrito
                            </button>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <% if (pagination.totalPages > 1) { %>
                    <nav class="public-pagination" aria-label="Páginas del catálogo">
                        <div class="public-pagination-desktop">
                            <% if (pagination.page > 1) { %>
                                <a class="public-page-link public-page-link--wide"
                                    href="<%= publicUrl({ page: pagination.page - 1 }) %>#catalogo" rel="prev">
                                    <i class="fa-solid fa-chevron-left"></i> Anterior
                                </a>
                            <% } else { %>
                                <span class="public-page-link public-page-link--wide is-disabled" aria-disabled="true">
                                    <i class="fa-solid fa-chevron-left"></i> Anterior
                                </span>
                            <% } %>

                            <div class="public-page-numbers">
                                <% for (let pageNumber = pageStart; pageNumber <= pageEnd; pageNumber += 1) { %>
                                    <% if (pageNumber === pagination.page) { %>
                                        <span class="public-page-link is-active" aria-current="page"><%= pageNumber %></span>
                                    <% } else { %>
                                        <a class="public-page-link" href="<%= publicUrl({ page: pageNumber }) %>#catalogo"
                                            aria-label="Ir a la página <%= pageNumber %>"><%= pageNumber %></a>
                                    <% } %>
                                <% } %>
                            </div>

                            <% if (pagination.page < pagination.totalPages) { %>
                                <a class="public-page-link public-page-link--wide"
                                    href="<%= publicUrl({ page: pagination.page + 1 }) %>#catalogo" rel="next">
                                    Siguiente <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            <% } else { %>
                                <span class="public-page-link public-page-link--wide is-disabled" aria-disabled="true">
                                    Siguiente <i class="fa-solid fa-chevron-right"></i>
                                </span>
                            <% } %>
                        </div>

                        <div class="public-pagination-mobile">
                            <% if (pagination.page > 1) { %>
                                <a class="public-page-link public-page-link--mobile"
                                    href="<%= publicUrl({ page: pagination.page - 1 }) %>#catalogo" rel="prev">
                                    <i class="fa-solid fa-chevron-left"></i> Anterior
                                </a>
                            <% } else { %>
                                <span class="public-page-link public-page-link--mobile is-disabled" aria-disabled="true">
                                    <i class="fa-solid fa-chevron-left"></i> Anterior
                                </span>
                            <% } %>

                            <span class="public-mobile-page-status">
                                <small>Página</small>
                                <strong><%= pagination.page %> de <%= pagination.totalPages %></strong>
                            </span>

                            <% if (pagination.page < pagination.totalPages) { %>
                                <a class="public-page-link public-page-link--mobile"
                                    href="<%= publicUrl({ page: pagination.page + 1 }) %>#catalogo" rel="next">
                                    Siguiente <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            <% } else { %>
                                <span class="public-page-link public-page-link--mobile is-disabled" aria-disabled="true">
                                    Siguiente <i class="fa-solid fa-chevron-right"></i>
                                </span>
                            <% } %>
                        </div>
                    </nav>
                <% } %>
            <% } %>
        </main>

        <!-- Product Details Modal -->
        <div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content product-modal-content">
                    <div class="modal-header border-0 pb-0">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body pt-0 px-4 pb-4">
                        <div class="row align-items-center">
                            <!-- Image Column -->
                            <div class="col-md-6 text-center mb-4 mb-md-0">
                                <div class="product-modal-image-shell">
                                    <img id="modalProductImage" src="" alt="Imagen del producto"
                                        class="img-fluid product-modal-image">
                                </div>
                            </div>
                            <!-- Details Column -->
                            <div class="col-md-6">
                                <h3 id="modalProductTitle" class="fw-bold mb-3 product-modal-title"></h3>

                                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                                    <div>
                                        <span id="modalProductOldPrice" class="product-modal-old-price"></span>
                                        <span id="modalProductPrice" class="fs-4 fw-bold product-modal-price"></span>
                                        <span id="modalOfferBadge" class="product-modal-offer-badge"></span>
                                    </div>
                                    <span id="modalProductStock" class="badge rounded-pill px-3 py-2 product-modal-stock">
                                        <i class="fa-solid fa-boxes-stacked me-1"></i> Stock: <span
                                            id="modalStockValue"></span>
                                    </span>
                                </div>

                                <div class="mb-4">
                                    <h6 class="fw-bold text-muted text-uppercase product-modal-section-label">Descripción:</h6>
                                    <p id="modalProductDescription" class="product-modal-description">
                                    </p>
                                </div>

                                <p class="text-muted small mb-4">
                                    <i class="fa-solid fa-barcode me-1"></i> Código: <span id="modalProductCode"
                                        class="fw-bold"></span>
                                </p>

                                <button id="modalAddCartBtn" type="button"
                                    class="btn btn-add-cart w-100 py-3 rounded-pill fw-bold fs-6">
                                    <i class="fa-solid fa-cart-plus fs-5 me-2 align-middle"></i>
                                    Añadir al carrito
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Floating Cart Button -->
        <div id="floatingCartBtn" class="floating-cart rounded-circle shadow-lg" data-toggle="modal"
            data-target="#cartModal">
            <i class="fa-solid fa-cart-shopping"></i>
            <span id="cartBadge" class="badge badge-danger rounded-circle position-absolute cart-badge">0</span>
        </div>

        <div id="cartToast" class="cart-toast" role="status" aria-live="polite" aria-atomic="true">
            <span class="cart-toast-icon"><i class="fa-solid fa-check"></i></span>
            <span class="cart-toast-copy">
                <strong id="cartToastTitle">Agregado al carrito</strong>
                <span id="cartToastProduct"></span>
            </span>
        </div>

        <!-- Cart Modal -->
        <div class="modal fade" id="cartModal" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content cart-modal-content">
                    <div class="modal-header bg-light cart-modal-header">
                        <h5 class="modal-title font-weight-bold" id="cartModalLabel">
                            <i class="fa-solid fa-cart-shopping me-2 cart-modal-title-icon"></i> Mi
                            Carrito
                        </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body p-0">
                        <div id="cartEmptyMessage" class="text-center p-5 text-muted">
                            <i class="fa-solid fa-basket-shopping fa-3x mb-3 cart-empty-icon"></i>
                            <p>Tu carrito está vacío.</p>
                        </div>
                        <ul id="cartItemsList" class="list-group list-group-flush">
                            <!-- Items se llenan con JS -->
                        </ul>
                    </div>
                    <div class="modal-footer bg-light cart-modal-footer">
                        <div class="font-weight-bold text-dark fs-5">Total: $<span id="cartTotal">0</span></div>
                        <button type="button" id="btnSendOrder" class="btn btn-whatsapp rounded-pill px-4"
                            onclick="sendWhatsAppOrder()">
                            <i class="fa-brands fa-whatsapp mr-1"></i> Pedir por WhatsApp
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // --- Lógica del Carrito ---
            function loadCart() {
                try {
                    const savedCart = JSON.parse(localStorage.getItem('solnatura_cart'));
                    if (!Array.isArray(savedCart)) return [];

                    return savedCart.reduce((validItems, item) => {
                        if (!item || typeof item !== 'object') return validItems;

                        const precio = Number(item.precio);
                        const cantidad = Number.parseInt(item.cantidad, 10);
                        const codigo = String(item.codigo || '').trim();

                        if (!codigo || !Number.isFinite(precio) || precio < 0) return validItems;

                        validItems.push({
                            title: String(item.title || 'Producto'),
                            codigo,
                            ciclo: String(item.ciclo || ''),
                            precio,
                            cantidad: Number.isInteger(cantidad) && cantidad > 0 ? cantidad : 1,
                        });
                        return validItems;
                    }, []);
                } catch (error) {
                    localStorage.removeItem('solnatura_cart');
                    return [];
                }
            }

            let cart = loadCart();
            let cartToastTimer;

            function addToCart(title, codigo, ciclo, precio) {
                // Check if product already exists
                const existingItemIndex = cart.findIndex(item => item.codigo === codigo && item.ciclo === ciclo);
                const quantityUpdated = existingItemIndex > -1;

                if (quantityUpdated) {
                    // Increase quantity if it exists
                    cart[existingItemIndex].cantidad = (cart[existingItemIndex].cantidad || 1) + 1;
                } else {
                    // Add new item with quantity 1
                    cart.push({ title, codigo, ciclo, precio, cantidad: 1 });
                }

                saveCart();
                renderCart();
                animateCartBadge();
                showCartConfirmation(title, quantityUpdated);
            }

            function showCartToast(title, message) {
                const toast = document.getElementById('cartToast');
                const toastTitle = document.getElementById('cartToastTitle');
                const toastProduct = document.getElementById('cartToastProduct');

                toastTitle.textContent = title;
                toastProduct.textContent = message;
                toast.classList.remove('is-visible');
                void toast.offsetWidth;
                toast.classList.add('is-visible');

                clearTimeout(cartToastTimer);
                cartToastTimer = setTimeout(() => toast.classList.remove('is-visible'), 2600);
            }

            function showCartConfirmation(title, quantityUpdated) {
                showCartToast(quantityUpdated ? 'Cantidad actualizada' : 'Agregado al carrito', title);
            }

            function removeFromCart(index) {
                cart.splice(index, 1);
                saveCart();
                renderCart();
            }

            function updateQuantity(index, delta) {
                if (cart[index].cantidad + delta > 0) {
                    cart[index].cantidad += delta;
                } else {
                    // If quantity reaches 0, remove the item
                    cart.splice(index, 1);
                }
                saveCart();
                renderCart();
            }

            function saveCart() {
                localStorage.setItem('solnatura_cart', JSON.stringify(cart));
            }

            function renderCart() {
                const badge = document.getElementById('cartBadge');
                const emptyMsg = document.getElementById('cartEmptyMessage');
                const list = document.getElementById('cartItemsList');
                const totalEl = document.getElementById('cartTotal');
                const btnSend = document.getElementById('btnSendOrder');

                // Calculate total items (sum of all quantities)
                const totalItems = cart.reduce((sum, item) => sum + (item.cantidad || 1), 0);
                badge.textContent = totalItems;
                list.replaceChildren();

                if (cart.length === 0) {
                    emptyMsg.style.display = 'block';
                    totalEl.textContent = '0';
                    btnSend.disabled = true;
                } else {
                    emptyMsg.style.display = 'none';
                    btnSend.disabled = false;

                    let total = 0;

                    cart.forEach((item, index) => {
                        const cantidad = item.cantidad || 1;
                        const subtotal = parseFloat(item.precio) * cantidad;
                        total += subtotal;

                        const row = document.createElement('li');
                        row.className = 'list-group-item d-flex justify-content-between align-items-center cart-item-row';

                        const itemMain = document.createElement('div');
                        itemMain.className = 'cart-item-main';

                        const itemTitle = document.createElement('h6');
                        itemTitle.className = 'mb-0 text-dark font-weight-bold cart-item-title';
                        itemTitle.textContent = item.title;

                        const itemMeta = document.createElement('small');
                        itemMeta.className = 'text-muted';
                        itemMeta.textContent = `Cód: ${item.codigo}${item.ciclo ? ` - Ciclo: ${item.ciclo}` : ''}`;

                        itemMain.append(itemTitle, itemMeta);

                        const actions = document.createElement('div');
                        actions.className = 'd-flex align-items-center cart-item-actions';

                        const quantityControl = document.createElement('div');
                        quantityControl.className = 'input-group input-group-sm cart-quantity-control';

                        const decrementShell = document.createElement('div');
                        decrementShell.className = 'input-group-prepend';
                        const decrementButton = document.createElement('button');
                        decrementButton.className = 'btn btn-outline-secondary';
                        decrementButton.type = 'button';
                        decrementButton.setAttribute('aria-label', `Disminuir cantidad de ${item.title}`);
                        decrementButton.textContent = '−';
                        decrementButton.addEventListener('click', () => updateQuantity(index, -1));
                        decrementShell.appendChild(decrementButton);

                        const quantityInput = document.createElement('input');
                        quantityInput.type = 'text';
                        quantityInput.className = 'form-control text-center px-0 bg-white';
                        quantityInput.value = cantidad;
                        quantityInput.readOnly = true;
                        quantityInput.setAttribute('aria-label', `Cantidad de ${item.title}`);

                        const incrementShell = document.createElement('div');
                        incrementShell.className = 'input-group-append';
                        const incrementButton = document.createElement('button');
                        incrementButton.className = 'btn btn-outline-secondary';
                        incrementButton.type = 'button';
                        incrementButton.setAttribute('aria-label', `Aumentar cantidad de ${item.title}`);
                        incrementButton.textContent = '+';
                        incrementButton.addEventListener('click', () => updateQuantity(index, 1));
                        incrementShell.appendChild(incrementButton);

                        quantityControl.append(decrementShell, quantityInput, incrementShell);

                        const subtotalElement = document.createElement('span');
                        subtotalElement.className = 'font-weight-bold text-success cart-item-subtotal';
                        subtotalElement.textContent = `$${subtotal.toLocaleString('es-CL')}`;

                        const removeButton = document.createElement('button');
                        removeButton.type = 'button';
                        removeButton.className = 'btn btn-sm btn-outline-danger border-0';
                        removeButton.setAttribute('aria-label', `Eliminar ${item.title} del carrito`);
                        removeButton.addEventListener('click', () => removeFromCart(index));
                        const removeIcon = document.createElement('i');
                        removeIcon.className = 'fa-solid fa-trash';
                        removeIcon.setAttribute('aria-hidden', 'true');
                        removeButton.appendChild(removeIcon);

                        actions.append(quantityControl, subtotalElement, removeButton);
                        row.append(itemMain, actions);
                        list.appendChild(row);
                    });

                    totalEl.textContent = total.toLocaleString('es-CL'); // Formato de miles
                }
            }

            function animateCartBadge() {
                const badge = document.getElementById('cartBadge');
                badge.classList.remove('animate__animated', 'animate__bounceIn');
                void badge.offsetWidth; // trigger reflow
                badge.classList.add('animate__animated', 'animate__bounceIn');
            }

            function sendWhatsAppOrder() {
                if (cart.length === 0) return;

                let message = '🌿 *¡Hola Solnatura!* Me gustaría realizar el siguiente pedido por favor:\n\n';
                let total = 0;

                cart.forEach((item, index) => {
                    const cantidad = item.cantidad || 1;
                    const subtotal = parseFloat(item.precio) * cantidad;
                    total += subtotal;

                    message += `*${index + 1}.* ${item.title} (Cód: ${item.codigo})\n`;
                    if (cantidad > 1) {
                        message += `   ${cantidad}x $${parseFloat(item.precio).toLocaleString('es-CL')} = $${subtotal.toLocaleString('es-CL')}\n`;
                    } else {
                        message += `   Valor: $${subtotal.toLocaleString('es-CL')}\n`;
                    }
                });

                message += `\n*Total estimado:* $${total.toLocaleString('es-CL')}\n\n`;
                message += 'Quedo atento/a para coordinar. ¡Gracias!';

                const whatsappUrl = 'https://api.whatsapp.com/send?phone=56992513285&text=' + encodeURIComponent(message);
                const whatsappWindow = window.open(whatsappUrl, '_blank');

                if (!whatsappWindow) {
                    showCartToast('No pudimos abrir WhatsApp', 'Permite las ventanas emergentes e inténtalo nuevamente.');
                    return;
                }

                whatsappWindow.opener = null;
                $('#cartModal').modal('hide');
                showCartToast('WhatsApp abierto', 'Tu carrito seguirá guardado hasta que decidas vaciarlo.');
            }

            // --- Lógica del Modal Info Producto (Actualizada) ---
            $(document).ready(function () {
                // Initialize cart on load
                renderCart();

                document.querySelectorAll('[data-cart-add]').forEach((button) => {
                    button.addEventListener('click', function (event) {
                        event.stopPropagation();
                        const productCard = button.closest('.product-card');
                        if (!productCard) return;

                        addToCart(
                            productCard.dataset.title,
                            productCard.dataset.codigo,
                            productCard.dataset.ciclo,
                            productCard.dataset.precio
                        );
                    });
                });

                $('#productModal').on('show.bs.modal', function (event) {
                    var button = $(event.relatedTarget);
                    var title = button.data('title');
                    var description = button.data('description');
                    var precio = button.data('precio');
                    var precioAnterior = button.data('precio-anterior');
                    var stock = button.data('stock');
                    var codigo = button.data('codigo');
                    var ciclo = button.data('ciclo');
                    var imagePath = button.data('path');

                    var modal = $(this);
                    modal.find('#modalProductTitle').text(title);
                    modal.find('#modalProductDescription').text(description);
                    modal.find('#modalProductPrice').text('$ ' + (parseInt(precio) || 0).toLocaleString('es-CL'));
                    modal.find('#modalStockValue').text(stock);
                    modal.find('#modalProductCode').text(codigo);
                    modal.find('#modalProductImage').attr('src', imagePath);
                    modal.find('#modalProductImage').attr('alt', title);

                    const oldPriceNum = parseInt(precioAnterior) || 0;
                    const priceNum = parseInt(precio) || 0;

                    if (oldPriceNum > priceNum) {
                        const discount = Math.round((1 - priceNum / oldPriceNum) * 100);
                        modal.find('#modalProductOldPrice').text('$ ' + oldPriceNum.toLocaleString('es-CL')).show();
                        modal.find('#modalOfferBadge').text('-' + discount + '%').show();
                    } else {
                        modal.find('#modalProductOldPrice').hide();
                        modal.find('#modalOfferBadge').hide();
                    }

                    // Actualizar botón de añadir al carrito del modal
                    const addBtn = document.getElementById('modalAddCartBtn');
                    // Remover listeners antiguos clonando el nodo
                    const newBtn = addBtn.cloneNode(true);
                    addBtn.parentNode.replaceChild(newBtn, addBtn);

                    newBtn.addEventListener('click', function () {
                        addToCart(title, codigo, ciclo, precio);
                        $('#productModal').modal('hide'); // Opcional: cerrar modal tras añadir
                    });
                });
            });
        </script>
</body>

</html>
