<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Productos — Solnatura</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigation") %>

        <!-- Hero Banner -->
        <section class="hero-section">
            <div class="hero-overlay"></div>
            <div class="hero-content animate__animated animate__fadeIn">
                <span class="hero-tagline">
                    <i class="fa-solid fa-leaf"></i> Productos 100% natura
                </span>
                <h1 class="hero-title">Bienvenido a <strong>Solnatura</strong></h1>
                <p class="hero-subtitle">Descubre nuestra selección de productos natura, directamente para tu
                    bienestar.</p>
                <form class="hero-search-form" action="/search_pub" method="post" enctype="multipart/form-data">
                    <div class="hero-search-group">
                        <i class="fa-solid fa-magnifying-glass hero-search-icon"></i>
                        <input type="search" name="buscar" class="hero-search-input" placeholder="¿Qué producto buscas?"
                            aria-label="Buscar" />
                        <button type="submit" class="hero-search-btn">Buscar</button>
                    </div>
                </form>
            </div>
        </section>

        <div class="container p-4">
            <div class="catalogo-grid">
                <% images.forEach(function (image) { %>
                    <div class="card animate__animated animate__fadeInUp" style="cursor: pointer;" data-toggle="modal"
                        data-target="#productModal" data-title="<%= image.title %>"
                        data-description="<%= image.description %>" data-precio="<%= image.precio %>"
                        data-precio-anterior="<%= image.precioAnterior || 0 %>" data-stock="<%= image.cantidad %>"
                        data-codigo="<%= image.codigo %>" data-ciclo="<%= image.ciclo %>" data-path="<%= image.path %>">
                        <div class="card-img-wrapper skeleton-loading">
                            <img src="<%= image.path %>" class="card-img-top" alt="<%= image.title %>"
                                onload="this.parentElement.classList.remove('skeleton-loading'); this.style.opacity = 1;"
                                style="opacity: 0; transition: opacity 0.3s ease-in-out;" loading="lazy" />
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <%= image.title %>
                            </h5>

                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div>
                                    <% if (image.precioAnterior && image.precioAnterior> image.precio) { %>
                                        <span
                                            style="color: #a0a0a0; text-decoration: line-through; font-size: 0.85rem; display: block; line-height: 1; margin-bottom: 2px;">$
                                            <%= (image.precioAnterior || 0).toLocaleString('es-CL') %>
                                        </span>
                                        <% } %>
                                            <span class="badge-precio" style="line-height: 1;">$ <%= (image.precio ||
                                                    0).toLocaleString('es-CL') %></span>
                                            <% if (image.precioAnterior && image.precioAnterior> image.precio) { %>
                                                <span
                                                    style="background-color: #ffe6e6; color: #d63031; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; font-weight: bold; margin-left: 5px; vertical-align: middle;">¡OFERTA!</span>
                                                <% } %>
                                </div>
                                <span class="badge-stock">
                                    <i class="fa-solid fa-boxes-stacked"></i>
                                    Stock: <%= image.cantidad %>
                                </span>
                            </div>

                            <p class="text-muted small mb-1">
                                <i class="fa-solid fa-barcode"></i>
                                <%= image.codigo %>
                            </p>

                            <p class="text-muted small mb-3"
                                style="flex-grow:1; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical;">
                                <%= image.description %>
                            </p>

                            <button type="button"
                                onclick="event.stopPropagation(); addToCart('<%= image.title %>', '<%= image.codigo %>', '<%= image.ciclo %>', '<%= image.precio %>')"
                                class="btn btn-whatsapp btn-block mt-auto">
                                <i class="fa-solid fa-cart-plus"></i>
                                Añadir al carrito
                            </button>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>

        <!-- Product Details Modal -->
        <div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content"
                    style="border-radius: 1rem; border: none; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
                    <div class="modal-header border-0 pb-0">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body pt-0 px-4 pb-4">
                        <div class="row align-items-center">
                            <!-- Image Column -->
                            <div class="col-md-6 text-center mb-4 mb-md-0">
                                <div
                                    style="background-color: #f0f4f2; border-radius: 0.75rem; padding: 1.5rem; display: inline-block; width: 100%;">
                                    <img id="modalProductImage" src="" alt="Product Image" class="img-fluid"
                                        style="max-height: 350px; object-fit: contain;">
                                </div>
                            </div>
                            <!-- Details Column -->
                            <div class="col-md-6">
                                <h3 id="modalProductTitle" class="fw-bold mb-3" style="color: #2d3436;"></h3>

                                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                                    <div>
                                        <span id="modalProductOldPrice"
                                            style="color: #a0a0a0; text-decoration: line-through; font-size: 1rem; display: none; line-height: 1; margin-bottom: 2px;"></span>
                                        <span id="modalProductPrice" class="fs-4 fw-bold"
                                            style="color: #4a9a87; line-height: 1;"></span>
                                        <span id="modalOfferBadge"
                                            style="background-color: #ffe6e6; color: #d63031; padding: 3px 10px; border-radius: 12px; font-size: 0.85rem; font-weight: bold; margin-left: 8px; vertical-align: middle; display: none;">¡OFERTA!</span>
                                    </div>
                                    <span id="modalProductStock" class="badge rounded-pill px-3 py-2"
                                        style="background-color: #d4edda; color: #4a9a87; font-size: 0.9rem;">
                                        <i class="fa-solid fa-boxes-stacked me-1"></i> Stock: <span
                                            id="modalStockValue"></span>
                                    </span>
                                </div>

                                <div class="mb-4">
                                    <h6 class="fw-bold text-muted text-uppercase"
                                        style="font-size: 0.8rem; letter-spacing: 0.05em;">Descripción:</h6>
                                    <p id="modalProductDescription"
                                        style="line-height: 1.6; color: #636e72; font-size: 0.95rem; white-space: pre-line;">
                                    </p>
                                </div>

                                <p class="text-muted small mb-4">
                                    <i class="fa-solid fa-barcode me-1"></i> Código: <span id="modalProductCode"
                                        class="fw-bold"></span>
                                </p>

                                <button id="modalAddCartBtn" type="button"
                                    class="btn btn-whatsapp w-100 py-3 rounded-pill fw-bold fs-6">
                                    <i class="fa-solid fa-cart-plus fs-5 me-2 align-middle"></i>
                                    Añadir al carrito
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Floating Cart Button -->
        <div id="floatingCartBtn" class="floating-cart rounded-circle shadow-lg" data-toggle="modal"
            data-target="#cartModal">
            <i class="fa-solid fa-cart-shopping"></i>
            <span id="cartBadge" class="badge badge-danger rounded-circle position-absolute cart-badge">0</span>
        </div>

        <!-- Cart Modal -->
        <div class="modal fade" id="cartModal" tabindex="-1" aria-labelledby="cartModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                <div class="modal-content"
                    style="border-radius: 1rem; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
                    <div class="modal-header bg-light"
                        style="border-top-left-radius: 1rem; border-top-right-radius: 1rem;">
                        <h5 class="modal-title font-weight-bold" id="cartModalLabel">
                            <i class="fa-solid fa-cart-shopping me-2" style="color: var(--verde-principal);"></i> Mi
                            Carrito
                        </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body p-0">
                        <div id="cartEmptyMessage" class="text-center p-5 text-muted">
                            <i class="fa-solid fa-basket-shopping fa-3x mb-3" style="color: #dee2e6;"></i>
                            <p>Tu carrito está vacío.</p>
                        </div>
                        <ul id="cartItemsList" class="list-group list-group-flush">
                            <!-- Items se llenan con JS -->
                        </ul>
                    </div>
                    <div class="modal-footer bg-light"
                        style="border-bottom-left-radius: 1rem; border-bottom-right-radius: 1rem; justify-content: space-between;">
                        <div class="font-weight-bold text-dark fs-5">Total: $<span id="cartTotal">0</span></div>
                        <button type="button" id="btnSendOrder" class="btn btn-whatsapp rounded-pill px-4"
                            onclick="showOrderForm()">
                            <i class="fa-brands fa-whatsapp mr-1"></i> Pedir por WhatsApp
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Customer Info Modal -->
        <div class="modal fade" id="orderFormModal" tabindex="-1" aria-labelledby="orderFormModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
                <div class="modal-content" style="border-radius: 1rem; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title font-weight-bold" id="orderFormModalLabel">
                            <i class="fa-brands fa-whatsapp mr-2" style="color: #25d366;"></i> Datos del pedido
                        </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body px-4 pb-4">
                        <div id="orderSaveWarning" class="alert alert-warning rounded-pill py-2 px-3 small mb-3"
                            style="display: none;">
                            <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                            No se pudo registrar el pedido en el servidor, pero tu mensaje de WhatsApp fue enviado.
                        </div>
                        <p class="text-muted small mb-3">Opcional — nos ayuda a identificar tu pedido.</p>
                        <div class="form-group mb-3">
                            <label class="small font-weight-700 text-muted text-uppercase">Nombre</label>
                            <input type="text" id="orderNombre" class="form-control rounded-pill px-3"
                                placeholder="Tu nombre (opcional)" />
                        </div>
                        <div class="form-group mb-3">
                            <label class="small font-weight-700 text-muted text-uppercase">Teléfono</label>
                            <input type="tel" id="orderTelefono" class="form-control rounded-pill px-3"
                                placeholder="Tu teléfono (opcional)" />
                        </div>
                        <div class="form-group mb-4">
                            <label class="small font-weight-700 text-muted text-uppercase">Notas</label>
                            <textarea id="orderNotas" class="form-control" rows="2"
                                style="border-radius: 0.75rem;"
                                placeholder="Comentarios o instrucciones de entrega (opcional)"></textarea>
                        </div>
                        <button type="button" id="btnConfirmOrder"
                            class="btn btn-block rounded-pill py-3 font-weight-800"
                            style="background-color: #25d366; color: white;"
                            onclick="sendWhatsAppOrder()">
                            <i class="fa-brands fa-whatsapp mr-2"></i> Confirmar y enviar por WhatsApp
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // --- Lógica del Carrito ---
            let cart = JSON.parse(localStorage.getItem('solnatura_cart')) || [];

            function addToCart(title, codigo, ciclo, precio) {
                // Check if product already exists
                const existingItemIndex = cart.findIndex(item => item.codigo === codigo && item.ciclo === ciclo);

                if (existingItemIndex > -1) {
                    // Increase quantity if it exists
                    cart[existingItemIndex].cantidad = (cart[existingItemIndex].cantidad || 1) + 1;
                } else {
                    // Add new item with quantity 1
                    cart.push({ title, codigo, ciclo, precio, cantidad: 1 });
                }

                saveCart();
                renderCart();
                animateCartBadge();
            }

            function removeFromCart(index) {
                cart.splice(index, 1);
                saveCart();
                renderCart();
            }

            function updateQuantity(index, delta) {
                if (cart[index].cantidad + delta > 0) {
                    cart[index].cantidad += delta;
                } else {
                    // If quantity reaches 0, remove the item
                    cart.splice(index, 1);
                }
                saveCart();
                renderCart();
            }

            function saveCart() {
                localStorage.setItem('solnatura_cart', JSON.stringify(cart));
            }

            function renderCart() {
                const badge = document.getElementById('cartBadge');
                const emptyMsg = document.getElementById('cartEmptyMessage');
                const list = document.getElementById('cartItemsList');
                const totalEl = document.getElementById('cartTotal');
                const btnSend = document.getElementById('btnSendOrder');

                // Calculate total items (sum of all quantities)
                const totalItems = cart.reduce((sum, item) => sum + (item.cantidad || 1), 0);
                badge.textContent = totalItems;

                if (cart.length === 0) {
                    emptyMsg.style.display = 'block';
                    list.innerHTML = '';
                    totalEl.textContent = '0';
                    btnSend.disabled = true;
                } else {
                    emptyMsg.style.display = 'none';
                    btnSend.disabled = false;

                    let html = '';
                    let total = 0;

                    cart.forEach((item, index) => {
                        const cantidad = item.cantidad || 1;
                        const subtotal = parseFloat(item.precio) * cantidad;
                        total += subtotal;

                        html += `
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div style="flex: 1;">
                                    <h6 class="mb-0 text-dark font-weight-bold" style="font-size: 0.95rem;">${item.title}</h6>
                                    <small class="text-muted">Cód: ${item.codigo} ${item.ciclo ? '- Ciclo: ' + item.ciclo : ''}</small>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="input-group input-group-sm" style="width: 90px; margin-right: 10px;">
                                        <div class="input-group-prepend">
                                            <button class="btn btn-outline-secondary" type="button" onclick="updateQuantity(${index}, -1)">-</button>
                                        </div>
                                        <input type="text" class="form-control text-center px-0 bg-white" value="${cantidad}" readonly>
                                        <div class="input-group-append">
                                            <button class="btn btn-outline-secondary" type="button" onclick="updateQuantity(${index}, 1)">+</button>
                                        </div>
                                    </div>
                                    <span class="font-weight-bold text-success" style="margin-right:10px; width: 60px; text-align: right;">$${subtotal.toLocaleString('es-CL')}</span>
                                    <button class="btn btn-sm btn-outline-danger border-0" onclick="removeFromCart(${index})">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </li>
                        `;
                    });

                    list.innerHTML = html;
                    totalEl.textContent = total.toLocaleString('es-CL'); // Formato de miles
                }
            }

            function animateCartBadge() {
                const badge = document.getElementById('cartBadge');
                badge.classList.remove('animate__animated', 'animate__bounceIn');
                void badge.offsetWidth; // trigger reflow
                badge.classList.add('animate__animated', 'animate__bounceIn');
            }

            function showOrderForm() {
                if (cart.length === 0) return;
                // Close cart modal and open customer info modal
                $('#cartModal').modal('hide');
                $('#orderFormModal').modal('show');
            }

            async function sendWhatsAppOrder() {
                if (cart.length === 0) return;

                const nombre   = (document.getElementById('orderNombre').value   || '').trim();
                const telefono = (document.getElementById('orderTelefono').value || '').trim();
                const notas    = (document.getElementById('orderNotas').value    || '').trim();

                // Calculate total once and reuse for both backend and WhatsApp message
                let total = 0;
                cart.forEach(item => {
                    total += parseFloat(item.precio) * (item.cantidad || 1);
                });

                // Save order to backend (non-blocking — if it fails, WhatsApp still opens)
                let savedOk = false;
                try {
                    const resp = await fetch('/pedido', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ items: cart, total, nombre, telefono, notas }),
                    });
                    savedOk = resp.ok;
                } catch (e) {
                    console.warn('No se pudo guardar el pedido en el servidor:', e);
                }

                if (!savedOk) {
                    const toast = document.getElementById('orderSaveWarning');
                    if (toast) { toast.style.display = 'block'; setTimeout(() => { toast.style.display = 'none'; }, 5000); }
                }

                // Build WhatsApp message
                let message = '🌿 *¡Hola Solnatura!* Me gustaría realizar el siguiente pedido por favor:\n\n';
                if (nombre) message += `*Nombre:* ${nombre}\n`;
                if (telefono) message += `*Teléfono:* ${telefono}\n`;
                if (nombre || telefono) message += '\n';

                cart.forEach((item, index) => {
                    const cantidad = item.cantidad || 1;
                    const subtotal = parseFloat(item.precio) * cantidad;
                    message += `*${index + 1}.* ${item.title} (Cód: ${item.codigo})\n`;
                    if (cantidad > 1) {
                        message += `   ${cantidad}x $${parseFloat(item.precio).toLocaleString('es-CL')} = $${subtotal.toLocaleString('es-CL')}\n`;
                    } else {
                        message += `   Valor: $${subtotal.toLocaleString('es-CL')}\n`;
                    }
                });

                message += `\n*Total estimado:* $${total.toLocaleString('es-CL')}\n`;
                if (notas) message += `\n*Notas:* ${notas}\n`;
                message += '\nQuedo atento/a para coordinar. ¡Gracias!';

                const whatsappUrl = 'https://api.whatsapp.com/send?phone=56992513285&text=' + encodeURIComponent(message);
                window.open(whatsappUrl, '_blank');

                // Clear form fields
                document.getElementById('orderNombre').value   = '';
                document.getElementById('orderTelefono').value = '';
                document.getElementById('orderNotas').value    = '';

                // Clear cart and close modal
                setTimeout(() => {
                    cart = [];
                    saveCart();
                    renderCart();
                    $('#orderFormModal').modal('hide');
                }, 500);
            }

            // --- Lógica del Modal Info Producto (Actualizada) ---
            $(document).ready(function () {
                // Initialize cart on load
                renderCart();

                $('#productModal').on('show.bs.modal', function (event) {
                    var button = $(event.relatedTarget);
                    var title = button.data('title');
                    var description = button.data('description');
                    var precio = button.data('precio');
                    var precioAnterior = button.data('precio-anterior');
                    var stock = button.data('stock');
                    var codigo = button.data('codigo');
                    var ciclo = button.data('ciclo');
                    var imagePath = button.data('path');

                    var modal = $(this);
                    modal.find('#modalProductTitle').text(title);
                    modal.find('#modalProductDescription').text(description);
                    modal.find('#modalProductPrice').text('$ ' + (parseInt(precio) || 0).toLocaleString('es-CL'));
                    modal.find('#modalStockValue').text(stock);
                    modal.find('#modalProductCode').text(codigo);
                    modal.find('#modalProductImage').attr('src', imagePath);

                    const oldPriceNum = parseInt(precioAnterior) || 0;
                    const priceNum = parseInt(precio) || 0;

                    if (oldPriceNum > priceNum) {
                        modal.find('#modalProductOldPrice').text('$ ' + oldPriceNum.toLocaleString('es-CL')).show();
                        modal.find('#modalOfferBadge').show();
                    } else {
                        modal.find('#modalProductOldPrice').hide();
                        modal.find('#modalOfferBadge').hide();
                    }

                    // Actualizar botón de añadir al carrito del modal
                    const addBtn = document.getElementById('modalAddCartBtn');
                    // Remover listeners antiguos clonando el nodo
                    const newBtn = addBtn.cloneNode(true);
                    addBtn.parentNode.replaceChild(newBtn, addBtn);

                    newBtn.addEventListener('click', function () {
                        addToCart(title, codigo, ciclo, precio);
                        $('#productModal').modal('hide'); // Opcional: cerrar modal tras añadir
                    });
                });
            });
        </script>
</body>

</html>