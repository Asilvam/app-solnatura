<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Producto</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigationM") %>

        <div class="container-fluid p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="font-weight-800 text-dark mb-0">Gestión de Catálogo</h2>
                <a href="/upload" class="btn btn-success rounded-pill px-4">
                    <i class="fa-solid fa-plus mr-2"></i> Nuevo Producto
                </a>
            </div>

            <div class="catalogo-grid">
                <% images.forEach(function (image) { %>
                    <div class="card animate__animated animate__fadeInUp">
                        <div class="card-img-wrapper">
                            <img src="<%= image.path %>" class="card-img-top" alt="<%= image.title %>" />
                            <!-- Badge de categoría flotante -->
                            <span class="position-absolute badge badge-light shadow-sm"
                                style="top: 10px; left: 10px; z-index: 2; border-radius: 20px; font-weight: 700; color: var(--verde-oscuro);">
                                <%= image.categoria %>
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">
                                <%= image.title %>
                            </h5>

                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="badge-precio">$ <%= image.precio %></span>
                                <span class="badge-stock">
                                    <i class="fa-solid fa-boxes-stacked"></i>
                                    <%= image.cantidad %>
                                </span>
                            </div>

                            <div class="d-flex justify-content-between small text-muted mb-2">
                                <span><i class="fa-solid fa-barcode"></i>
                                    <%= image.codigo %>
                                </span>
                                <span><i class="fa-solid fa-calendar-check"></i> Ciclo: <%= image.ciclo %></span>
                            </div>

                            <p class="text-muted small mb-3"
                                style="flex-grow:1; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical;">
                                <%= image.description %>
                            </p>

                            <div class="row no-gutters gap-2 mt-auto">
                                <div class="col-6 pr-1">
                                    <a href="/update/<%= image._id %>"
                                        class="btn btn-outline-primary btn-block btn-sm rounded-pill">
                                        <i class="fa-solid fa-pen-to-square"></i> Editar
                                    </a>
                                </div>
                                <div class="col-6 pl-1">
                                    <a href="/image/<%= image._id %>"
                                        class="btn btn-outline-danger btn-block btn-sm rounded-pill">
                                        <i class="fa-solid fa-trash-can"></i> Borrar
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
</body>

</html>