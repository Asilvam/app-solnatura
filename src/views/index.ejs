<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Producto</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigationM") %>

        <div class="container-fluid p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="font-weight-800 text-dark mb-0">Gestión de Catálogo</h2>
                <div>
                    <a href="/mode/stock" class="btn btn-warning rounded-pill px-4 mr-2">
                        <i class="fa-solid fa-triangle-exclamation mr-2"></i> Stock Bajo
                    </a>
                    <a href="/upload" class="btn btn-success rounded-pill px-4">
                        <i class="fa-solid fa-plus mr-2"></i> Nuevo Producto
                    </a>
                </div>
            </div>

            <% const sinStock = images.filter(i => (i.cantidad || 0) === 0).length;
               const stockBajo = images.filter(i => (i.cantidad || 0) > 0 && (i.cantidad || 0) <= 5).length;
               if (sinStock > 0 || stockBajo > 0) { %>
            <div class="alert rounded-pill d-flex align-items-center mb-4 py-2 px-4"
                style="background-color: #fff3cd; border: 1px solid #ffc107;">
                <i class="fa-solid fa-triangle-exclamation text-warning mr-3" style="font-size:1.2rem;"></i>
                <span class="font-weight-700 text-dark">
                    <% if (sinStock > 0) { %>
                        <span class="badge badge-danger rounded-pill mr-2"><%= sinStock %> sin stock</span>
                    <% } %>
                    <% if (stockBajo > 0) { %>
                        <span class="badge badge-warning rounded-pill mr-2"><%= stockBajo %> con stock bajo (≤5)</span>
                    <% } %>
                    — Usa el botón <strong>Stock</strong> en cada producto para ajustar.
                </span>
            </div>
            <% } %>

            <div class="catalogo-grid">
                <% images.forEach(function (image) { %>
                    <div class="card animate__animated animate__fadeInUp">
                        <div class="card-img-wrapper">
                            <img src="<%= image.path %>" class="card-img-top" alt="<%= image.title %>" />
                            <!-- Badge de categoría flotante -->
                            <span class="position-absolute badge badge-light shadow-sm"
                                style="top: 10px; left: 10px; z-index: 2; border-radius: 20px; font-weight: 700; color: var(--verde-oscuro);">
                                <%= image.categoria %>
                            </span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">
                                <%= image.title %>
                            </h5>

                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="badge-precio">$ <%= image.precio %></span>
                                <span class="badge-stock <% if ((image.cantidad || 0) === 0) { %>badge-stock-empty<% } else if ((image.cantidad || 0) <= 5) { %>badge-stock-low<% } %>">
                                    <i class="fa-solid fa-boxes-stacked"></i>
                                    <%= image.cantidad || 0 %>
                                    <% if ((image.cantidad || 0) === 0) { %>
                                        <i class="fa-solid fa-triangle-exclamation ml-1" title="Sin stock"></i>
                                    <% } else if ((image.cantidad || 0) <= 5) { %>
                                        <i class="fa-solid fa-circle-exclamation ml-1" title="Stock bajo"></i>
                                    <% } %>
                                </span>
                            </div>

                            <div class="d-flex justify-content-between small text-muted mb-2">
                                <span><i class="fa-solid fa-barcode"></i>
                                    <%= image.codigo %>
                                </span>
                                <span><i class="fa-solid fa-calendar-check"></i> Ciclo: <%= image.ciclo %></span>
                            </div>

                            <p class="text-muted small mb-3"
                                style="flex-grow:1; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; line-clamp:2; -webkit-box-orient:vertical;">
                                <%= image.description %>
                            </p>

                            <div class="row no-gutters gap-2 mt-auto">
                                <div class="col-4 pr-1">
                                    <a href="/update/<%= image._id %>"
                                        class="btn btn-outline-primary btn-block btn-sm rounded-pill">
                                        <i class="fa-solid fa-pen-to-square"></i> Editar
                                    </a>
                                </div>
                                <div class="col-4 px-1">
                                    <a href="/stock/<%= image._id %>"
                                        class="btn btn-outline-success btn-block btn-sm rounded-pill">
                                        <i class="fa-solid fa-boxes-stacked"></i> Stock
                                    </a>
                                </div>
                                <div class="col-4 pl-1">
                                    <a href="/image/<%= image._id %>"
                                        class="btn btn-outline-danger btn-block btn-sm rounded-pill">
                                        <i class="fa-solid fa-trash-can"></i> Borrar
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
</body>

</html>