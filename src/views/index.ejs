<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Producto</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigationM") %>

        <main class="container-fluid admin-catalog-page p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
                <div class="mb-2 mb-md-0">
                    <h2 class="font-weight-800 text-dark mb-1">Gestión de Catálogo</h2>
                    <p class="text-muted mb-0">Controla vigencia, stock, precios y categorías desde un solo lugar.</p>
                </div>
                <a href="/upload" class="btn btn-success rounded-pill px-4 py-2">
                    <i class="fa-solid fa-plus mr-2"></i> Nuevo Producto
                </a>
            </div>

            <% if (notice) { %>
                <div class="alert alert-info admin-notice" role="status">
                    <i class="fa-solid fa-circle-info mr-2"></i><%= notice %>
                </div>
            <% } %>

            <section class="admin-summary-grid mb-4" aria-label="Resumen del catálogo">
                <a href="/mode" class="admin-summary-card admin-summary-card--total">
                    <span class="admin-summary-icon"><i class="fa-solid fa-boxes-stacked"></i></span>
                    <span><strong><%= stats.total %></strong><small>Total</small></span>
                </a>
                <a href="/mode?estado=vigente" class="admin-summary-card admin-summary-card--active">
                    <span class="admin-summary-icon"><i class="fa-solid fa-circle-check"></i></span>
                    <span><strong><%= stats.vigentes %></strong><small>Vigentes</small></span>
                </a>
                <a href="/mode?stock=sin-stock" class="admin-summary-card admin-summary-card--empty">
                    <span class="admin-summary-icon"><i class="fa-solid fa-box-open"></i></span>
                    <span><strong><%= stats.sinStock %></strong><small>Sin stock</small></span>
                </a>
                <a href="/mode?stock=bajo" class="admin-summary-card admin-summary-card--low">
                    <span class="admin-summary-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                    <span><strong><%= stats.stockBajo %></strong><small>Stock bajo</small></span>
                </a>
                <a href="/mode?oferta=si" class="admin-summary-card admin-summary-card--offer">
                    <span class="admin-summary-icon"><i class="fa-solid fa-tags"></i></span>
                    <span><strong><%= stats.ofertas %></strong><small>En oferta</small></span>
                </a>
            </section>

            <section class="admin-filter-card mb-4">
                <form action="/mode" method="get">
                    <div class="row align-items-end">
                        <div class="col-xl-3 col-md-6">
                            <div class="form-group mb-3">
                                <label for="filter-q">Buscar</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                                    </div>
                                    <input id="filter-q" name="q" type="search" class="form-control"
                                        value="<%= filters.q %>" placeholder="Nombre, código o descripción" />
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-3 col-sm-6">
                            <div class="form-group mb-3">
                                <label for="filter-estado">Vigencia</label>
                                <select id="filter-estado" name="estado" class="form-control">
                                    <option value="">Todas</option>
                                    <option value="vigente" <%= filters.estado === "vigente" ? "selected" : "" %>>Vigentes</option>
                                    <option value="no-vigente" <%= filters.estado === "no-vigente" ? "selected" : "" %>>No vigentes</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-3 col-sm-6">
                            <div class="form-group mb-3">
                                <label for="filter-stock">Stock</label>
                                <select id="filter-stock" name="stock" class="form-control">
                                    <option value="">Cualquier stock</option>
                                    <option value="con-stock" <%= filters.stock === "con-stock" ? "selected" : "" %>>Con stock</option>
                                    <option value="sin-stock" <%= filters.stock === "sin-stock" ? "selected" : "" %>>Sin stock</option>
                                    <option value="bajo" <%= filters.stock === "bajo" ? "selected" : "" %>>Bajo (1–<%= lowStockLimit %>)</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4 col-sm-6">
                            <div class="form-group mb-3">
                                <label for="filter-categoria">Categoría</label>
                                <select id="filter-categoria" name="categoria" class="form-control">
                                    <option value="">Todas</option>
                                    <% categorias.forEach(function (categoria) { %>
                                        <option value="<%= categoria.codigo %>" <%= filters.categoria === categoria.codigo ? "selected" : "" %>>
                                            <%= categoria.nombre %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                        <div class="col-xl-1 col-md-4 col-sm-6">
                            <div class="form-group mb-3">
                                <label for="filter-oferta">Oferta</label>
                                <select id="filter-oferta" name="oferta" class="form-control">
                                    <option value="">Todas</option>
                                    <option value="si" <%= filters.oferta === "si" ? "selected" : "" %>>Sí</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-xl-2 col-md-4">
                            <div class="form-group mb-3">
                                <label for="filter-orden">Ordenar</label>
                                <select id="filter-orden" name="orden" class="form-control">
                                    <option value="recientes" <%= filters.orden === "recientes" ? "selected" : "" %>>Más recientes</option>
                                    <option value="antiguos" <%= filters.orden === "antiguos" ? "selected" : "" %>>Más antiguos</option>
                                    <option value="nombre_asc" <%= filters.orden === "nombre_asc" ? "selected" : "" %>>Nombre A–Z</option>
                                    <option value="nombre_desc" <%= filters.orden === "nombre_desc" ? "selected" : "" %>>Nombre Z–A</option>
                                    <option value="precio_asc" <%= filters.orden === "precio_asc" ? "selected" : "" %>>Precio menor</option>
                                    <option value="precio_desc" <%= filters.orden === "precio_desc" ? "selected" : "" %>>Precio mayor</option>
                                    <option value="stock_asc" <%= filters.orden === "stock_asc" ? "selected" : "" %>>Menor stock</option>
                                    <option value="stock_desc" <%= filters.orden === "stock_desc" ? "selected" : "" %>>Mayor stock</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap justify-content-between align-items-end admin-filter-actions">
                        <div class="admin-page-size-control">
                            <label for="filter-page-size" class="mb-0">Productos por página</label>
                            <select id="filter-page-size" name="porPagina" class="form-control form-control-sm">
                                <option value="12" <%= filters.porPagina === 12 ? "selected" : "" %>>12</option>
                                <option value="24" <%= filters.porPagina === 24 ? "selected" : "" %>>24</option>
                                <option value="36" <%= filters.porPagina === 36 ? "selected" : "" %>>36</option>
                                <option value="48" <%= filters.porPagina === 48 ? "selected" : "" %>>48</option>
                            </select>
                        </div>
                        <div class="admin-filter-action-buttons">
                            <a href="/mode" class="btn btn-light rounded-pill px-4 mr-2">
                                <i class="fa-solid fa-rotate-left mr-1"></i> Limpiar
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="fa-solid fa-filter mr-1"></i> Aplicar filtros
                            </button>
                        </div>
                    </div>
                </form>
            </section>

            <div class="admin-catalog-results-header mb-3">
                <p class="text-muted mb-0">
                    <strong class="text-dark"><%= pagination.total %></strong>
                    <%= pagination.total === 1 ? "producto encontrado" : "productos encontrados" %>
                </p>
                <% if (pagination.totalPages > 1) { %>
                    <% let firstVisiblePage = Math.max(1, pagination.page - 2); %>
                    <% let lastVisiblePage = Math.min(pagination.totalPages, firstVisiblePage + 4); %>
                    <% firstVisiblePage = Math.max(1, lastVisiblePage - 4); %>
                    <div class="admin-catalog-page-position">
                        <small class="text-muted">Página <%= pagination.page %> de <%= pagination.totalPages %></small>
                        <nav aria-label="Paginación del catálogo" class="admin-catalog-pagination">
                            <ul class="pagination justify-content-end flex-wrap mb-0">
                                <li class="page-item <%= pagination.page === 1 ? "disabled" : "" %>">
                                    <a class="page-link admin-page-link--jump" href="<%= modeUrl({ page: 1 }) %>"
                                        aria-label="Ir a la primera página" title="Primera página">
                                        <i class="fa-solid fa-angles-left"></i>
                                    </a>
                                </li>
                                <li class="page-item <%= pagination.page === 1 ? "disabled" : "" %>">
                                    <a class="page-link" href="<%= modeUrl({ page: pagination.page - 1 }) %>"
                                        aria-label="Página anterior">
                                        <i class="fa-solid fa-chevron-left"></i>
                                    </a>
                                </li>
                                <% for (let pageNumber = firstVisiblePage; pageNumber <= lastVisiblePage; pageNumber += 1) { %>
                                    <li class="page-item <%= pageNumber === pagination.page ? "active" : "" %>">
                                        <a class="page-link" href="<%= modeUrl({ page: pageNumber }) %>"
                                            <%= pageNumber === pagination.page ? 'aria-current="page"' : '' %>><%= pageNumber %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%= pagination.page === pagination.totalPages ? "disabled" : "" %>">
                                    <a class="page-link" href="<%= modeUrl({ page: pagination.page + 1 }) %>"
                                        aria-label="Página siguiente">
                                        <i class="fa-solid fa-chevron-right"></i>
                                    </a>
                                </li>
                                <li class="page-item <%= pagination.page === pagination.totalPages ? "disabled" : "" %>">
                                    <a class="page-link admin-page-link--jump" href="<%= modeUrl({ page: pagination.totalPages }) %>"
                                        aria-label="Ir a la última página" title="Última página">
                                        <i class="fa-solid fa-angles-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                <% } %>
            </div>

            <% if (images.length > 0) { %>
                <form id="bulkProductForm" action="/mode/bulk" method="post" class="admin-bulk-bar mb-3">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="returnTo" value="<%= currentModeUrl %>" />
                    <label class="admin-select-all mb-0" for="selectAllProducts">
                        <input id="selectAllProducts" type="checkbox" />
                        <span><strong id="selectedProductCount">0</strong> seleccionados</span>
                    </label>
                    <select id="bulkAction" name="bulkAction" class="form-control form-control-sm admin-bulk-action" required>
                        <option value="">Acción masiva…</option>
                        <option value="activar">Marcar vigentes</option>
                        <option value="desactivar">Marcar no vigentes</option>
                        <option value="categoria">Cambiar categoría</option>
                    </select>
                    <select id="bulkCategory" name="bulkCategory" class="form-control form-control-sm admin-bulk-category" disabled>
                        <option value="">Nueva categoría…</option>
                        <% categorias.forEach(function (categoria) { %>
                            <option value="<%= categoria.codigo %>"><%= categoria.nombre %></option>
                        <% }) %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3">
                        <i class="fa-solid fa-wand-magic-sparkles mr-1"></i> Aplicar
                    </button>
                    <a href="<%= exportUrl %>" class="btn btn-outline-primary btn-sm rounded-pill px-3 admin-export-link">
                        <i class="fa-solid fa-file-excel mr-1"></i> Exportar Excel
                    </a>
                </form>
            <% } %>

            <% if (images.length === 0) { %>
                <div class="admin-empty-state">
                    <i class="fa-solid fa-filter-circle-xmark"></i>
                    <h4>No encontramos productos</h4>
                    <p>Prueba eliminando uno o más filtros.</p>
                    <a href="/mode" class="btn btn-outline-primary rounded-pill px-4">Ver todo el catálogo</a>
                </div>
            <% } else { %>
                <div class="catalogo-grid">
                    <% images.forEach(function (image) { %>
                        <article class="card admin-product-card animate__animated animate__fadeInUp"
                            data-low-stock-limit="<%= lowStockLimit %>">
                            <div class="card-img-wrapper">
                                <img src="<%= image.path %>" class="card-img-top" alt="<%= image.title %>" />
                                <span class="admin-category-line"
                                    title="<%= categoryNames[image.categoria] || image.categoria %>">
                                    <%= categoryNames[image.categoria] || image.categoria %>
                                </span>
                                <label class="admin-product-selector" title="Seleccionar producto">
                                    <input type="checkbox" class="product-select" name="productIds"
                                        value="<%= image._id %>" form="bulkProductForm"
                                        aria-label="Seleccionar <%= image.title %>" />
                                    <span><i class="fa-solid fa-check"></i></span>
                                </label>
                                <% if (!image.estado) { %>
                                    <span class="badge-no-vigente-diagonal">No vigente</span>
                                <% } %>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-truncate"><%= image.title %></h5>
                                <div class="admin-card-metrics mb-2">
                                    <span class="badge-precio">$ <%= (image.precio || 0).toLocaleString("es-CL") %></span>
                                    <div class="admin-card-stock-control">
                                        <span class="badge-stock <%= image.cantidad <= 0 ? "badge-stock--empty" : (image.cantidad <= lowStockLimit ? "badge-stock--low" : "") %>"
                                            data-stock-label>
                                            <i class="fa-solid fa-boxes-stacked"></i> Stock: <%= image.cantidad || 0 %>
                                        </span>
                                        <div class="admin-card-stock-buttons" aria-label="Ajustar stock de <%= image.title %>">
                                            <form action="/mode/<%= image._id %>/stock" method="post" class="admin-stock-form">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                                <input type="hidden" name="returnTo" value="<%= currentModeUrl %>" />
                                                <input type="hidden" name="delta" value="-1" />
                                                <button type="submit" class="btn btn-outline-warning btn-sm"
                                                    aria-label="Restar una unidad a <%= image.title %>"
                                                    <%= image.cantidad <= 0 ? "disabled" : "" %>>−</button>
                                            </form>
                                            <form action="/mode/<%= image._id %>/stock" method="post" class="admin-stock-form">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                                <input type="hidden" name="returnTo" value="<%= currentModeUrl %>" />
                                                <input type="hidden" name="delta" value="1" />
                                                <button type="submit" class="btn btn-outline-success btn-sm"
                                                    aria-label="Sumar una unidad a <%= image.title %>">+</button>
                                            </form>
                                        </div>
                                        <small class="admin-stock-feedback" role="status" aria-live="polite"></small>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between small text-muted mb-2">
                                    <span><i class="fa-solid fa-barcode"></i> <%= image.codigo %></span>
                                    <span><i class="fa-solid fa-calendar-check"></i> Ciclo: <%= image.ciclo %></span>
                                </div>
                                <p class="text-muted small mb-3 admin-product-description"><%= image.description %></p>
                                <div class="row no-gutters mt-auto">
                                    <div class="col-6 pr-1">
                                        <a href="/update/<%= image._id %>?returnTo=<%= encodeURIComponent(currentModeUrl) %>"
                                            class="btn btn-outline-primary btn-block btn-sm rounded-pill">
                                            <i class="fa-solid fa-pen-to-square"></i> Editar
                                        </a>
                                    </div>
                                    <div class="col-6 pl-1">
                                        <button type="button"
                                            class="btn btn-outline-danger btn-block btn-sm rounded-pill admin-delete-trigger"
                                            data-toggle="modal" data-target="#deleteProductModal"
                                            data-product-id="<%= image._id %>"
                                            data-product-title="<%= image.title %>"
                                            data-product-code="<%= image.codigo %>"
                                            data-product-image="<%= image.path %>">
                                            <i class="fa-solid fa-trash-can"></i> Borrar
                                        </button>
                                    </div>
                                </div>
                                <form action="/mode/<%= image._id %>/estado" method="post" class="mt-2 admin-status-form">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                    <input type="hidden" name="estado" value="<%= image.estado ? "false" : "true" %>"
                                        data-state-input />
                                    <input type="hidden" name="returnTo" value="<%= currentModeUrl %>" />
                                    <button type="submit" data-state-button
                                        class="btn btn-block btn-sm rounded-pill <%= image.estado ? "btn-outline-warning" : "btn-outline-success" %>">
                                        <i class="fa-solid <%= image.estado ? "fa-eye-slash" : "fa-eye" %> mr-1"></i>
                                        <%= image.estado ? "Marcar no vigente" : "Activar producto" %>
                                    </button>
                                    <small class="admin-status-feedback" role="status" aria-live="polite"></small>
                                </form>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } %>

        </main>

        <div class="modal fade" id="deleteProductModal" tabindex="-1" role="dialog"
            aria-labelledby="deleteProductModalTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content admin-delete-modal">
                    <div class="modal-header admin-delete-modal-header">
                        <div class="admin-delete-modal-heading">
                            <span class="admin-delete-modal-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                            <div>
                                <small>Confirmar eliminación</small>
                                <h5 class="modal-title" id="deleteProductModalTitle">¿Borrar este producto?</h5>
                            </div>
                        </div>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="admin-delete-product-preview">
                            <div class="admin-delete-product-image">
                                <img id="deleteProductImage" src="" alt="" />
                            </div>
                            <div class="admin-delete-product-copy">
                                <strong id="deleteProductName"></strong>
                                <span id="deleteProductCode"></span>
                            </div>
                        </div>
                        <div class="admin-delete-warning mb-0">
                            <i class="fa-solid fa-cloud-arrow-down"></i>
                            <p>
                                Se eliminarán permanentemente el producto de la base de datos y su imagen de Cloudinary.
                                <strong>Esta acción no se puede deshacer.</strong>
                            </p>
                        </div>
                    </div>
                    <div class="modal-footer admin-delete-modal-footer">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-dismiss="modal">
                            Cancelar
                        </button>
                        <form id="deleteProductForm" method="post">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <input type="hidden" name="returnTo" value="<%= currentModeUrl %>" />
                            <button type="submit" class="btn btn-danger rounded-pill px-4">
                                <i class="fa-solid fa-trash-can mr-2"></i>Sí, borrar permanentemente
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const stockForms = Array.from(document.querySelectorAll('.admin-stock-form'));
                const stockFeedbackTimers = new WeakMap();

                stockForms.forEach((form) => {
                    form.addEventListener('submit', async function (event) {
                        event.preventDefault();

                        const card = form.closest('.admin-product-card');
                        const control = form.closest('.admin-card-stock-control');
                        const badge = control.querySelector('[data-stock-label]');
                        const feedback = control.querySelector('.admin-stock-feedback');
                        const buttons = Array.from(control.querySelectorAll('button'));
                        const decrementButton = control.querySelector('input[value="-1"]').closest('form').querySelector('button');
                        const lowStockLimit = Number(card.dataset.lowStockLimit) || 5;

                        buttons.forEach((button) => { button.disabled = true; });
                        control.setAttribute('aria-busy', 'true');
                        feedback.textContent = '';
                        feedback.classList.remove('is-error');

                        try {
                            const response = await fetch(form.action, {
                                method: 'POST',
                                body: new URLSearchParams(new FormData(form)),
                                headers: {
                                    Accept: 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest',
                                },
                            });
                            const result = await response.json().catch(() => ({
                                ok: false,
                                message: 'El servidor devolvió una respuesta inesperada.',
                            }));
                            if (!response.ok || !result.ok) {
                                throw new Error(result.message || 'No se pudo actualizar el stock.');
                            }

                            const stock = Number(result.stock) || 0;
                            badge.innerHTML = `<i class="fa-solid fa-boxes-stacked"></i> Stock: ${stock}`;
                            badge.classList.toggle('badge-stock--empty', stock <= 0);
                            badge.classList.toggle('badge-stock--low', stock > 0 && stock <= lowStockLimit);
                            decrementButton.disabled = stock <= 0;
                            updateCardStatus(card, result.estado);
                            feedback.textContent = 'Actualizado';

                            const previousTimer = stockFeedbackTimers.get(feedback);
                            if (previousTimer) window.clearTimeout(previousTimer);
                            const feedbackTimer = window.setTimeout(() => {
                                if (feedback.textContent === 'Actualizado') feedback.textContent = '';
                            }, 1400);
                            stockFeedbackTimers.set(feedback, feedbackTimer);
                        } catch (error) {
                            const previousTimer = stockFeedbackTimers.get(feedback);
                            if (previousTimer) window.clearTimeout(previousTimer);
                            feedback.textContent = error.message;
                            feedback.classList.add('is-error');
                        } finally {
                            buttons.forEach((button) => { button.disabled = false; });
                            const currentStock = Number(badge.textContent.replace(/\D/g, '')) || 0;
                            decrementButton.disabled = currentStock <= 0;
                            control.removeAttribute('aria-busy');
                        }
                    });
                });

                function updateCardStatus(card, isActive) {
                    const imageWrapper = card.querySelector('.card-img-wrapper');
                    let inactiveRibbon = imageWrapper.querySelector('.badge-no-vigente-diagonal');
                    const stateInput = card.querySelector('[data-state-input]');
                    const stateButton = card.querySelector('[data-state-button]');

                    if (isActive && inactiveRibbon) {
                        inactiveRibbon.remove();
                    } else if (!isActive && !inactiveRibbon) {
                        inactiveRibbon = document.createElement('span');
                        inactiveRibbon.className = 'badge-no-vigente-diagonal';
                        inactiveRibbon.textContent = 'No vigente';
                        imageWrapper.appendChild(inactiveRibbon);
                    }

                    stateInput.value = isActive ? 'false' : 'true';
                    stateButton.classList.toggle('btn-outline-warning', isActive);
                    stateButton.classList.toggle('btn-outline-success', !isActive);
                    stateButton.innerHTML = isActive
                        ? '<i class="fa-solid fa-eye-slash mr-1"></i> Marcar no vigente'
                        : '<i class="fa-solid fa-eye mr-1"></i> Activar producto';
                }

                const statusForms = Array.from(document.querySelectorAll('.admin-status-form'));
                const statusFeedbackTimers = new WeakMap();

                statusForms.forEach((form) => {
                    form.addEventListener('submit', async function (event) {
                        event.preventDefault();

                        const card = form.closest('.admin-product-card');
                        const button = form.querySelector('[data-state-button]');
                        const feedback = form.querySelector('.admin-status-feedback');

                        button.disabled = true;
                        form.setAttribute('aria-busy', 'true');
                        feedback.textContent = '';
                        feedback.classList.remove('is-error');

                        try {
                            const response = await fetch(form.action, {
                                method: 'POST',
                                body: new URLSearchParams(new FormData(form)),
                                headers: {
                                    Accept: 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest',
                                },
                            });
                            const result = await response.json().catch(() => ({
                                ok: false,
                                message: 'El servidor devolvió una respuesta inesperada.',
                            }));
                            if (!response.ok || !result.ok) {
                                throw new Error(result.message || 'No se pudo cambiar la vigencia.');
                            }

                            updateCardStatus(card, result.estado);
                            feedback.textContent = result.estado ? 'Producto vigente' : 'Producto no vigente';

                            const previousTimer = statusFeedbackTimers.get(feedback);
                            if (previousTimer) window.clearTimeout(previousTimer);
                            const feedbackTimer = window.setTimeout(() => {
                                feedback.textContent = '';
                            }, 1600);
                            statusFeedbackTimers.set(feedback, feedbackTimer);
                        } catch (error) {
                            const previousTimer = statusFeedbackTimers.get(feedback);
                            if (previousTimer) window.clearTimeout(previousTimer);
                            feedback.textContent = error.message;
                            feedback.classList.add('is-error');
                        } finally {
                            button.disabled = false;
                            form.removeAttribute('aria-busy');
                        }
                    });
                });

                const deleteForm = document.getElementById('deleteProductForm');
                const deleteProductName = document.getElementById('deleteProductName');
                const deleteProductCode = document.getElementById('deleteProductCode');
                const deleteProductImage = document.getElementById('deleteProductImage');

                document.querySelectorAll('.admin-delete-trigger').forEach((button) => {
                    button.addEventListener('click', function () {
                        const productId = button.dataset.productId;
                        const productTitle = button.dataset.productTitle;

                        deleteForm.action = `/image/${encodeURIComponent(productId)}/delete`;
                        deleteProductName.textContent = productTitle;
                        deleteProductCode.textContent = `Código: ${button.dataset.productCode}`;
                        deleteProductImage.src = button.dataset.productImage;
                        deleteProductImage.alt = productTitle;
                    });
                });

                const bulkForm = document.getElementById('bulkProductForm');
                if (!bulkForm) return;

                const selectAll = document.getElementById('selectAllProducts');
                const selections = Array.from(document.querySelectorAll('.product-select'));
                const selectedCount = document.getElementById('selectedProductCount');
                const bulkAction = document.getElementById('bulkAction');
                const bulkCategory = document.getElementById('bulkCategory');

                function updateSelectionState() {
                    const count = selections.filter((checkbox) => checkbox.checked).length;
                    selections.forEach((checkbox) => {
                        const card = checkbox.closest('.admin-product-card');
                        if (card) card.classList.toggle('is-selected', checkbox.checked);
                    });
                    selectedCount.textContent = count;
                    selectAll.checked = count > 0 && count === selections.length;
                    selectAll.indeterminate = count > 0 && count < selections.length;
                    document.body.classList.toggle('admin-selection-active', count > 0);
                }

                selectAll.addEventListener('change', function () {
                    selections.forEach((checkbox) => {
                        checkbox.checked = selectAll.checked;
                    });
                    updateSelectionState();
                });

                selections.forEach((checkbox) => checkbox.addEventListener('change', updateSelectionState));

                bulkAction.addEventListener('change', function () {
                    const needsCategory = bulkAction.value === 'categoria';
                    bulkCategory.disabled = !needsCategory;
                    bulkCategory.required = needsCategory;
                    if (!needsCategory) bulkCategory.value = '';
                });

                bulkForm.addEventListener('submit', function (event) {
                    const count = selections.filter((checkbox) => checkbox.checked).length;
                    if (count === 0) {
                        event.preventDefault();
                        alert('Selecciona al menos un producto.');
                        return;
                    }

                    if (!confirm(`¿Aplicar esta acción a ${count} producto${count === 1 ? '' : 's'}?`)) {
                        event.preventDefault();
                    }
                });
            });
        </script>
</body>

</html>
