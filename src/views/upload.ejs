<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Subir Producto</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigationM") %>

        <div class="container p-4">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-md-8">
                    <div class="card shadow-sm border-0" style="border-radius: 1.25rem; overflow: hidden;">
                        <div class="card-header bg-success text-white text-center py-4 border-0">
                            <h3 class="font-weight-800 mb-0"><i class="fa-solid fa-cloud-arrow-up mr-2"></i>Nuevo
                                Producto</h3>
                        </div>
                        <div class="card-body p-4 p-md-5">
                            <form action="/upload" method="post" enctype="multipart/form-data">

                                <div class="form-group mb-4">
                                    <label class="small font-weight-700 text-muted text-uppercase mb-2">Imagen del
                                        Producto</label>
                                    <div class="custom-file">
                                        <input type="file" name="image" class="custom-file-input" id="inputItemImg"
                                            lang="es" autofocus required />
                                        <label class="custom-file-label rounded-pill" for="inputItemImg"
                                            data-browse="Elegir">Seleccionar archivo...</label>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-group mb-3">
                                            <label class="small font-weight-700 text-muted text-uppercase">Nombre del
                                                Producto</label>
                                            <input type="text" name="title" placeholder="Ej: Crema Hidratante Tododia"
                                                class="form-control rounded-pill px-3" required />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group mb-3">
                                            <label class="small font-weight-700 text-muted text-uppercase">Stock
                                                Inicial</label>
                                            <input type="number" name="cantidad" placeholder="0"
                                                class="form-control rounded-pill px-3" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-3">
                                            <label class="small font-weight-700 text-muted text-uppercase">Precio
                                                Venta</label>
                                            <div class="input-group">
                                                <div class="input-group-prepend">
                                                    <span
                                                        class="input-group-text bg-white border-right-0 rounded-pill-left pl-3">$</span>
                                                </div>
                                                <input type="number" name="precio" placeholder="0"
                                                    class="form-control border-left-0 rounded-pill-right pr-3" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group mb-3">
                                            <label
                                                class="small font-weight-700 text-muted text-uppercase">Código</label>
                                            <input type="text" name="codigo" placeholder="Ej: 12345"
                                                class="form-control rounded-pill px-3" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group mb-3">
                                            <label class="small font-weight-700 text-muted text-uppercase">Ciclo</label>
                                            <input type="text" name="ciclo" placeholder="Ej: 05/2024"
                                                class="form-control rounded-pill px-3" />
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group mb-4">
                                    <label class="small font-weight-700 text-muted text-uppercase">Categoría</label>
                                    <select name="categoria" class="form-control rounded-pill px-3"
                                        id="FormControlSelect1">
                                        <option selected disabled>Seleccionar...</option>
                                        <% categorias.forEach(function (categoria) { %>
                                            <option value="<%= categoria.codigo %>">
                                                <%= categoria.nombre %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>

                                <div class="form-group mb-4">
                                    <label class="small font-weight-700 text-muted text-uppercase">Descripción
                                        Detallada</label>
                                    <textarea name="description"
                                        placeholder="Describe los beneficios, aromas o componentes..."
                                        class="form-control" style="border-radius: 1rem; min-height: 100px;"></textarea>
                                </div>

                                <div class="form-group mt-4">
                                    <button
                                        class="btn btn-success btn-block rounded-pill py-3 font-weight-800 shadow-sm">
                                        <i class="fa-solid fa-floppy-disk mr-2"></i> GUARDAR PRODUCTO
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .rounded-pill-left {
                border-top-left-radius: 50rem;
                border-bottom-left-radius: 50rem;
            }

            .rounded-pill-right {
                border-top-right-radius: 50rem;
                border-bottom-right-radius: 50rem;
            }

            .custom-file-label::after {
                border-top-right-radius: 50rem;
                border-bottom-right-radius: 50rem;
            }
        </style>
</body>

</html>