<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <link rel="shortcut icon" href="https://res.cloudinary.com/dujg9sojg/image/upload/v1591400278/favicon-32x32.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>Subir Categoria</title>
    <%- include("partials/head") -%>
</head>

<body>
    <%- include("partials/navigationM") %>

        <div class="container p-4">
            <div class="row">
                <div class="col-lg-5 mb-4">
                    <div class="card shadow-sm border-0" style="border-radius: 1rem;">
                        <div class="card-header bg-white border-0 pt-4 text-center">
                            <h4 class="font-weight-800 text-dark"><i
                                    class="fa-solid fa-folder-plus text-success mr-2"></i>Nueva Categoría</h4>
                        </div>
                        <div class="card-body">
                            <form action="/modecat" method="post" enctype="multipart/form-data">
                                <div class="form-group">
                                    <label class="small font-weight-700 text-muted">Código</label>
                                    <input type="text" name="codigo" placeholder="Ej: ROSTRO"
                                        class="form-control rounded-pill px-3" required />
                                </div>
                                <div class="form-group">
                                    <label class="small font-weight-700 text-muted">Nombre</label>
                                    <input type="text" name="nombre" placeholder="Ej: Cuidado del Rostro"
                                        class="form-control rounded-pill px-3" required />
                                </div>
                                <div class="form-group mt-4">
                                    <button class="btn btn-success btn-block rounded-pill py-2 font-weight-700">
                                        <i class="fa-solid fa-floppy-disk mr-2"></i> Guardar Categoría
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="row">
                        <% categorias.forEach(function (categoria) { %>
                            <div class="col-md-6 mb-3">
                                <div class="card shadow-sm border-0"
                                    style="border-radius: 1rem; border-left: 5px solid var(--verde-principal) !important;">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span
                                                class="badge badge-light px-3 py-2 rounded-pill text-uppercase font-weight-700"
                                                style="color: var(--verde-oscuro);">
                                                <%= categoria.codigo %>
                                            </span>
                                            <span class="small text-muted font-weight-600">
                                                <%= categoria.estado %>
                                            </span>
                                        </div>
                                        <h5 class="font-weight-800 text-dark mb-4">
                                            <%= categoria.nombre %>
                                        </h5>
                                        <a href="/categoria/<%= categoria._id %>/delete"
                                            class="btn btn-outline-danger btn-sm btn-block rounded-pill">
                                            <i class="fa-solid fa-trash-can mr-1"></i> Borrar
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </div>
        </div>
</body>

</html>